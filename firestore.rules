rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Leads collection rules
    match /leads/{leadId} {
      allow read, write: if true;
    }

    // Settings collection rules
    match /settings/{settingId} {
      allow read, write: if true;
    }
  }
}
